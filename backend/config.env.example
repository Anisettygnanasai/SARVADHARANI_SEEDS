DB_USER=postgres
DB_PASSWORD=your_postgres_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=accounting_app
# Optional for production (Render etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# If DATABASE_URL is set, it takes priority over DB_HOST/DB_USER/DB_PASSWORD/DB_NAME
JWT_SECRET_KEY=replace-with-a-long-random-secret

# SMTP settings for registration verification & forgot-password OTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
